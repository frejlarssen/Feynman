{
  "experiment_name": "qft_feynman_extreme",
  "binary": "build-release/sv_prefetcher_subset_mpi.x",
  "mpirun": "mpirun",
  "ranks": 16,
  "feynman_env": {
    "OMP_NUM_THREADS": "2"
  },
  "circuit": {
    "generator": "qft",
    "n": 24,
    "k": 2
  },
  "input_statevector": {
    "generator": "two_freq",
    "size": 3,
    "f1": 6,
    "f2": 4194304,
    "f2_amp": 0.2,
    "threshold": 0.99999999
  },
  "output_bitstrings": {
    "generator": "two_intervals",
    "size": 3,
    "interval1": {
      "start": 0,
      "count": 10
    },
    "interval2": {
      "start": 4194299,
      "count": 10
    }
  },
  "fraction": 1.0,
  "threshold": 0.0,
  "batch_size": 32,
  "verbosity": 1,
  "dense": false,
  "normalize_input": true,
  "plot_max_xticks": 20,
  "output_root": "data/outputs/validation"
}

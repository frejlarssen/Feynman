{
  "experiment_name": "qft_n8_k2_checkpoint_ablation",
  "repo_root": ".",
  "vary": "batch_size",
  "values": [32],
  "repeat": 5,
  "ranks": 4,
  "batch_size": 32,
  "fraction": 1.0,
  "threshold": 1e-8,
  "circuit": {
    "generator": "qft",
    "n": 8,
    "k": 2
  },
  "input_statevector": {
    "generator": "ket0",
    "size": 1
  },
  "output_bitstrings": {
    "generator": "one_interval",
    "size": 1,
    "count": 10
  },
  "cases": [
    {
      "name": "no_cp",
      "p": 0,
      "r": 0
    },
    {
      "name": "fixed_cp",
      "p": 8,
      "r": 8
    },
    {
      "name": "autotuned_cp",
      "p": null,
      "r": null
    }
  ],
  "notes": "Checkpoint ablation: no_cp vs fixed_cp vs autotuned_cp on qft_n8_k2."
}
